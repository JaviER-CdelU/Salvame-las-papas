rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "salvamelaspapascdelu@gmail.com";
    }

    match /comercios/{comercioId} {
      // Público: solo comercios activos.
      // Propietario y administrador: también pueden leer sus registros no activos.
      allow read: if resource.data.estado == "activo"
                  || isAdmin()
                  || (signedIn() && resource.data.ownerUid == request.auth.uid);

      allow create: if signedIn()
                    && request.resource.data.ownerUid == request.auth.uid;

      allow update, delete: if isAdmin()
                            || (signedIn() && resource.data.ownerUid == request.auth.uid);

      match /productos/{productoId} {
        allow read: if
          get(/databases/$(database)/documents/comercios/$(comercioId)).data.estado == "activo"
          || isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/comercios/$(comercioId)).data.ownerUid == request.auth.uid
          );

        allow create, update, delete: if isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/comercios/$(comercioId)).data.ownerUid == request.auth.uid
          );
      }
    }

    match /pedidos/{pedidoId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      allow read, write: if signedIn() && request.auth.uid == usuarioId;
    }

    // Denegar cualquier otra colección no declarada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
