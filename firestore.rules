rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "salvamelaspapascdelu@gmail.com";
    }

    function isSellerOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /comercios/{comercioId} {
      allow read: if isAdmin()
                  || (signedIn() && resource.data.ownerUid == request.auth.uid)
                  || resource.data.estado == "activo";

      allow create: if signedIn();

      allow update, delete: if isAdmin()
                            || (signedIn() && resource.data.ownerUid == request.auth.uid);

      match /productos/{productoId} {
        allow read: if isAdmin()
                    || get(/databases/$(database)/documents/comercios/$(comercioId)).data.estado == "activo"
                    || (signedIn()
                        && get(/databases/$(database)/documents/comercios/$(comercioId)).data.ownerUid == request.auth.uid);

        allow create, update, delete: if isAdmin()
          || (signedIn()
              && get(/databases/$(database)/documents/comercios/$(comercioId)).data.ownerUid == request.auth.uid);
      }
    }

    match /vendedoresParticulares/{publicacionId} {
      allow create: if signedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.tipo == "vendedor_particular"
                    && request.resource.data.estado == "pendiente"
                    && request.resource.data.estadoPago == "pendiente"
                    && request.resource.data.nombre is string
                    && request.resource.data.nombre.size() >= 2
                    && request.resource.data.whatsapp is string
                    && request.resource.data.whatsapp.size() >= 8
                    && request.resource.data.articulos is list
                    && request.resource.data.articulos.size() >= 1
                    && request.resource.data.articulos.size() <= 2;

      allow read: if isAdmin()
                  || isSellerOwner()
                  || resource.data.estado == "activo";

      allow update: if isAdmin()
                    || (
                      isSellerOwner()
                      && request.resource.data.ownerUid == resource.data.ownerUid
                      && request.resource.data.estado == resource.data.estado
                      && request.resource.data.estadoPago == resource.data.estadoPago
                      && request.resource.data.plan == resource.data.plan
                      && request.resource.data.vencimiento == resource.data.vencimiento
                      && request.resource.data.articulos is list
                      && request.resource.data.articulos.size() >= 1
                      && request.resource.data.articulos.size() <= 2
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(["articulos", "actualizadoEn"])
                    );

      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      allow read, write: if signedIn() && request.auth.uid == usuarioId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
